{
  "name": "auth-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --port 8890",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "typecheck": "tsc --noEmit",
    "check:contract": "node ./scripts/check-api-contract.mjs",
    "db:migrate:local": "wrangler d1 migrations apply betterauth_auth --local",
    "db:migrate:dev": "wrangler d1 migrations apply betterauth_auth_dev --remote --env dev",
    "db:migrate:remote": "wrangler d1 migrations apply betterauth_auth --remote",
    "db:query:local": "wrangler d1 execute betterauth_auth --local --command \"SELECT 1 as ok;\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "description": "Cloudflare Worker Better Auth service with D1 + KV foundation.",
  "dependencies": {
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
